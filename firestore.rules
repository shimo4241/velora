rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function connectionIdMatchesOwnerPair(connectionId) {
      return connectionId == request.resource.data.userId + "_" + request.resource.data.connectedUserId;
    }

    function reservedUsernames() {
      return [
        "admin",
        "api",
        "app",
        "account",
        "accounts",
        "about",
        "billing",
        "business",
        "contact",
        "dashboard",
        "discover",
        "help",
        "home",
        "legal",
        "login",
        "logout",
        "mail",
        "network",
        "nfc",
        "premium",
        "privacy",
        "profile",
        "profiles",
        "qr",
        "register",
        "settings",
        "share",
        "signin",
        "signup",
        "sms",
        "support",
        "terms",
        "u",
        "user",
        "users",
        "velora",
        "wallet",
        "whatsapp",
        "www"
      ];
    }

    function validUsername(username) {
      return username is string
        && username.matches("^[a-z0-9]{3,30}$")
        && !(username in reservedUsernames());
    }

    function hasUsernameReservationAfter(userId, username) {
      return existsAfter(/databases/$(database)/documents/usernames/$(username))
        && getAfter(/databases/$(database)/documents/usernames/$(username)).data.uid == userId;
    }

    // Public immutable username reservation.
    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn()
        && validUsername(username)
        && request.resource.data.username == username
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId)
        && validUsername(request.resource.data.username)
        && hasUsernameReservationAfter(userId, request.resource.data.username)
        && !("location_geo" in request.resource.data)
        && (!("role" in request.resource.data) || request.resource.data.role == "free")
        && (!("isVerified" in request.resource.data) || request.resource.data.isVerified == false)
        && (!("isPremium" in request.resource.data) || request.resource.data.isPremium == false)
        && (!("isNoir" in request.resource.data) || request.resource.data.isNoir == false);
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["location_geo", "role", "isVerified", "isPremium", "isNoir"])
        && (
          (
            resource.data.username == request.resource.data.username
            && validUsername(request.resource.data.username)
          )
          || (
            !("username" in resource.data)
            && validUsername(request.resource.data.username)
            && hasUsernameReservationAfter(userId, request.resource.data.username)
          )
        );
      allow delete: if false;

      // Exact GPS is owner-only. Public docs may only expose location_geo_coarse.
      match /private_data/{privateId} {
        allow read, write: if isOwner(userId);
      }

      // Network subcollection - owner or the contact being added/removed
      match /network/{contactId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) || isOwner(contactId);
      }

      // Portfolio subcollection - owner only
      match /portfolio/{itemId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // Experience subcollection - owner only
      match /experience/{entryId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // Connections
    match /connections/{connectionId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
                    && (request.resource.data.userId == request.auth.uid || request.resource.data.connectedUserId == request.auth.uid)
                    && request.resource.data.userId != request.resource.data.connectedUserId
                    && connectionIdMatchesOwnerPair(connectionId);
      allow update: if signedIn()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.connectedUserId == resource.data.connectedUserId;
      allow delete: if signedIn()
                    && (resource.data.userId == request.auth.uid || resource.data.connectedUserId == request.auth.uid);
    }

    // Conversations and Messages (Direct Messaging)
    match /conversations/{conversationId} {
      allow read: if signedIn()
                  && request.auth.uid in resource.data.participants;
      allow create: if signedIn()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() == 2
                    && exists(/databases/$(database)/documents/connections/$(request.resource.data.participants[0] + "_" + request.resource.data.participants[1]));
      allow update: if signedIn()
                    && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn()
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if signedIn()
                      && request.auth.uid == request.resource.data.senderId
                      && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow update, delete: if false;
      }
    }

    // Optional owner-only private notes collection for future scaling.
    match /connection_notes/{noteId} {
      allow read, write: if signedIn()
        && (
          (resource.data.userId == request.auth.uid)
          || (request.resource.data.userId == request.auth.uid)
        );
    }

    // Contact Requests — sender and receiver can read; sender creates; both can update/delete
    match /contact_requests/{requestId} {
      allow read: if signedIn()
                  && (resource.data.senderId == request.auth.uid
                      || resource.data.receiverId == request.auth.uid);
      allow create: if signedIn()
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.senderId != request.resource.data.receiverId
                    && requestId == request.resource.data.senderId + "_" + request.resource.data.receiverId;
      allow update: if signedIn()
                    && (
                      // Receiver can only accept/decline (updates status and updatedAt only)
                      (resource.data.receiverId == request.auth.uid
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"])
                      )
                      ||
                      // Sender can modify their request details, but cannot accept it themselves
                      (resource.data.senderId == request.auth.uid
                       && request.resource.data.senderId == resource.data.senderId
                       && request.resource.data.receiverId == resource.data.receiverId
                       && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(["status"]) || request.resource.data.status != "accepted")
                      )
                    );
      allow delete: if signedIn()
                    && (resource.data.senderId == request.auth.uid
                        || resource.data.receiverId == request.auth.uid);
    }

    // Blocked Users — only the blocker can read/write
    match /blocked_users/{blockId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.userId != request.resource.data.blockedUserId
                    && blockId == request.resource.data.userId + "_" + request.resource.data.blockedUserId;
      allow delete: if signedIn()
                    && resource.data.userId == request.auth.uid;
    }

    // Notifications — recipient reads/updates; any authenticated user creates
    match /notifications/{notifId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
                    && request.resource.data.userId != request.auth.uid
                    && request.resource.data.senderId == request.auth.uid;
      allow update: if signedIn()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"]);
      allow delete: if signedIn()
                    && resource.data.userId == request.auth.uid;
    }

    // Shares
    match /shares/{shareId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid;
    }

    // Analytics Events
    match /analytics_events/{eventId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
    }

    // Events — public read, admin/backend write only
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Event Attendees — public read, owner write
    match /event_attendees/{attendeeId} {
      allow read: if true;
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && attendeeId == request.resource.data.eventId + "_" + request.auth.uid;
      allow update: if signedIn()
                    && resource.data.userId == request.auth.uid;
      allow delete: if signedIn()
                    && resource.data.userId == request.auth.uid;
    }

    // Event Check-ins
    match /event_checkins/{checkinId} {
      allow read: if signedIn();
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Event Interests (lightweight)
    match /event_interests/{interestId} {
      allow read: if true;
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn()
                    && resource.data.userId == request.auth.uid;
    }
  }
}
