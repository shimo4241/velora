rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function reservedUsernames() {
      return [
        "admin",
        "api",
        "app",
        "account",
        "accounts",
        "about",
        "billing",
        "business",
        "contact",
        "dashboard",
        "discover",
        "help",
        "home",
        "legal",
        "login",
        "logout",
        "mail",
        "network",
        "nfc",
        "premium",
        "privacy",
        "profile",
        "profiles",
        "qr",
        "register",
        "settings",
        "share",
        "signin",
        "signup",
        "sms",
        "support",
        "terms",
        "u",
        "user",
        "users",
        "velora",
        "wallet",
        "whatsapp",
        "www"
      ];
    }

    function validUsername(username) {
      return username is string
        && username.matches("^[a-z0-9]{3,30}$")
        && !(username in reservedUsernames());
    }

    function hasUsernameReservationAfter(userId, username) {
      return existsAfter(/databases/$(database)/documents/usernames/$(username))
        && getAfter(/databases/$(database)/documents/usernames/$(username)).data.uid == userId;
    }

    // Public immutable username reservation.
    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn()
        && validUsername(username)
        && request.resource.data.username == username
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId)
        && validUsername(request.resource.data.username)
        && hasUsernameReservationAfter(userId, request.resource.data.username);
      allow update: if isOwner(userId)
        && (
          (
            resource.data.username == request.resource.data.username
            && validUsername(request.resource.data.username)
          )
          || (
            !("username" in resource.data)
            && validUsername(request.resource.data.username)
            && hasUsernameReservationAfter(userId, request.resource.data.username)
          )
        );
      allow delete: if false;

      // Portfolio subcollection - owner only
      match /portfolio/{itemId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // Experience subcollection - owner only
      match /experience/{entryId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // Connections
    match /connections/{connectionId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn()
                            && resource.data.userId == request.auth.uid;
    }

    // Shares
    match /shares/{shareId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid;
    }

    // Analytics Events
    match /analytics_events/{eventId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
    }
  }
}
