rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function connectionIdMatchesOwnerPair(connectionId) {
      return connectionId == request.resource.data.userId + "_" + request.resource.data.connectedUserId;
    }

    function reservedUsernames() {
      return [
        "admin",
        "api",
        "app",
        "account",
        "accounts",
        "about",
        "billing",
        "business",
        "contact",
        "dashboard",
        "discover",
        "help",
        "home",
        "legal",
        "login",
        "logout",
        "mail",
        "network",
        "nfc",
        "premium",
        "privacy",
        "profile",
        "profiles",
        "qr",
        "register",
        "settings",
        "share",
        "signin",
        "signup",
        "sms",
        "support",
        "terms",
        "u",
        "user",
        "users",
        "velora",
        "wallet",
        "whatsapp",
        "www"
      ];
    }

    function validUsername(username) {
      return username is string
        && username.matches("^[a-z0-9]{3,30}$")
        && !(username in reservedUsernames());
    }

    function hasUsernameReservationAfter(userId, username) {
      return existsAfter(/databases/$(database)/documents/usernames/$(username))
        && getAfter(/databases/$(database)/documents/usernames/$(username)).data.uid == userId;
    }

    // Public immutable username reservation.
    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn()
        && validUsername(username)
        && request.resource.data.username == username
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Users
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId)
        && validUsername(request.resource.data.username)
        && hasUsernameReservationAfter(userId, request.resource.data.username)
        && !("location_geo" in request.resource.data);
      allow update: if isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["location_geo"])
        && (
          (
            resource.data.username == request.resource.data.username
            && validUsername(request.resource.data.username)
          )
          || (
            !("username" in resource.data)
            && validUsername(request.resource.data.username)
            && hasUsernameReservationAfter(userId, request.resource.data.username)
          )
        );
      allow delete: if false;

      // Exact GPS is owner-only. Public docs may only expose location_geo_coarse.
      match /private_data/{privateId} {
        allow read, write: if isOwner(userId);
      }

      // Network subcollection - owner only
      match /network/{contactId} {
        allow read, write: if isOwner(userId);
      }

      // Portfolio subcollection - owner only
      match /portfolio/{itemId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }

      // Experience subcollection - owner only
      match /experience/{entryId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // Connections
    match /connections/{connectionId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.userId != request.resource.data.connectedUserId
                    && connectionIdMatchesOwnerPair(connectionId);
      allow update, delete: if signedIn()
                            && resource.data.userId == request.auth.uid;
    }

    // Optional owner-only private notes collection for future scaling.
    match /connection_notes/{noteId} {
      allow read, write: if signedIn()
        && (
          (resource.data.userId == request.auth.uid)
          || (request.resource.data.userId == request.auth.uid)
        );
    }

    // Contact Requests — sender and receiver can read; sender creates; both can update/delete
    match /contact_requests/{requestId} {
      allow read: if signedIn()
                  && (resource.data.senderId == request.auth.uid
                      || resource.data.receiverId == request.auth.uid);
      allow create: if signedIn()
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.senderId != request.resource.data.receiverId;
      allow update: if signedIn()
                    && (resource.data.senderId == request.auth.uid
                        || resource.data.receiverId == request.auth.uid);
      allow delete: if signedIn()
                    && (resource.data.senderId == request.auth.uid
                        || resource.data.receiverId == request.auth.uid);
    }

    // Blocked Users — only the blocker can read/write
    match /blocked_users/{blockId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.userId != request.resource.data.blockedUserId;
      allow delete: if signedIn()
                    && resource.data.userId == request.auth.uid;
    }

    // Notifications — recipient reads/updates; any authenticated user creates
    match /notifications/{notifId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
                    && request.resource.data.userId != request.auth.uid
                    && request.resource.data.senderId == request.auth.uid;
      allow update: if signedIn()
                    && resource.data.userId == request.auth.uid;
      allow delete: if signedIn()
                    && resource.data.userId == request.auth.uid;
    }

    // Shares
    match /shares/{shareId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
                    && request.resource.data.userId == request.auth.uid;
    }

    // Analytics Events
    match /analytics_events/{eventId} {
      allow read: if signedIn()
                  && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
    }
  }
}
